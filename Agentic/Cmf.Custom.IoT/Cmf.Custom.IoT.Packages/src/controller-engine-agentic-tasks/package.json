{
  "name": "@criticalmanufacturing/connect-iot-controller-engine-agentic-tasks",
  "version": "0.0.0",
  "description": "Generated Task Library package",
  "type": "module",
  "main": "dist/src/index.js",
  "typings": "dist/src/index",
  "scripts": {
    "build": "concurrently \"npm run build:runtime\" \"npm run build:tests\" \"npm run build:templates\" -r",
    "build:runtime": "tsc -p ./tsconfig.runtime.json",
    "build:templates": "tsc -p ./tsconfig.templates.json",
    "build:tests": "tsc -p ./tsconfig.tests.json",
    "tests": "mocha \"dist/test/**/*.test.js\" --timeout 30000 --retries 3 --exit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "watch": "npm run build -- -w | mocha --timeout 30000 --exit --reporter min -w dist/test/**/*.test.js",
    "watchPackage": "npm run build:runtime -- --preserveWatchOutput -w",
    "watchTests": "npm run build:tests -- --preserveWatchOutput -w",
    "tests:coverage": "nyc -r cobertura -r lcov -r text-summary npm run test -R mocha-multi-reporters --reporter-options configFile=mocha-multi-reporters-config.json",
    "generate:font": "cd font/svg && yo @criticalmanufacturing/iot:fontgen && cd ../../",
    "generateTask": "cmf new iot task",
    "generateConverter": "cmf new iot converter",
    "packagePacker": "packageBundler -d -o=."
  },
  "keywords": [
    "CMF",
    "IoT",
    "Agent"
  ],
  "devDependencies": {
    "@criticalmanufacturing/node-package-bundler": "latest",
    "@types/chai": "4.3.10",
    "@types/chai-spies": "1.0.6",
    "@types/mocha": "10.0.4",
    "@types/ms": "^2.1.0",
    "@types/node": "22.17.0",
    "chai": "4.3.10",
    "chai-spies": "1.1.0",
    "eslint-configs": "0.0.0",
    "mocha": "^11.7.5",
    "mocha-junit-reporter": "2.2.1",
    "mocha-lcov-reporter": "1.3.0",
    "mocha-multi-reporters": "1.5.1",
    "nyc": "15.1.0",
    "ts-configs": "^0.0.0",
    "tslint": "6.1.3",
    "typescript": "5.4.5"
  },
  "dependencies": {
    "@criticalmanufacturing/connect-iot-controller-engine": "release-1124",
    "@nodelib/fs.walk": "^3.0.1",
    "cmf-lbos": "release-1124",
    "inversify": "6.0.2",
    "moment": "2.29.4",
    "ms": "^2.1.3",
    "node-llama-cpp": "^3.16.2",
    "reflect-metadata": "0.1.13",
    "uuid": "^13.0.0",
    "zone.js": "0.14.7"
  },
  "engines": {
    "node": ">=20.15.0 <23"
  },
  "author": "Critical Manufacturing",
  "criticalManufacturing": {
    "tasksLibrary": {
      "displayName": "Agentic Library",
      "dependsOnScope": [],
      "mandatoryForScope": [],
      "dependsOnProtocol": [],
      "mandatoryForProtocol": [],
      "metadata": {
        "converters": [],
        "tasks": []
      }
    }
  }
}