{
  "version": "0.2.0",
  "inputs": [
    {
      "id": "managerLocation",
      "type": "promptString",
      "description": "Enter the location of the Automation Manager Downloaded",
      "default": "./Manager"
    },
    {
      "id": "managerId",
      "type": "promptString",
      "description": "Enter the 'Automation Manager ID' of the Automation Manager"
    }
  ],
  "configurations": [
    {
      "type": "node",
      "request": "launch",
      "name": "Start Manager",
      "program": "${input:managerLocation}/src/index.js",
      "args": [
        "--dev",
        "--config=${input:managerLocation}/config.json",
        "--monitorApplication=${input:managerLocation}/src/monitor.js",
        "--id=${input:managerId}"
      ],
      "cwd": "${workspaceRoot}",
      "outFiles": [],
      "outputCapture": "std",
      "autoAttachChildProcesses": true
    },
    {
      "name": "Run tests on Custom Agentic Tasks",
      "type": "node",
      "request": "launch",
      "program": "${workspaceRoot}/node_modules/mocha/bin/_mocha",
      "stopOnEntry": false,
      "args": [
        "dist/test/unit/**/*.test.js",
        "dist/test/unit/*.test.js",
        "--no-timeouts"
      ],
      "cwd": "${workspaceRoot}/src/controller-engine-agentic-tasks",
      "runtimeExecutable": null,
      "sourceMaps": true,
      "outputCapture": "std"
    }
  ]
}